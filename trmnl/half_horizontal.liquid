{% comment %} Weather Circles — half_horizontal (800x240) {% endcomment %}
<style>
  .wc        { height:100%; display:flex; align-items:stretch;
               font-family:-apple-system,Helvetica,Arial,sans-serif; color:#000; }
  .wc-cur    { flex:0 0 220px; display:flex; flex-direction:column; align-items:center;
               justify-content:center; text-align:center;
               border-right:2px solid #000; padding:10px 16px; }
  .wc-cur svg{ width:84px; height:84px; }
  .wc-temp   { font-size:40px; font-weight:800; line-height:1; }
  .wc-sum    { font-size:17px; font-weight:600; }
  .wc-hl     { font-size:14px; }
  .wc-grid   { flex:1; display:grid; grid-template-columns:repeat(4,1fr);
               align-items:center; padding:8px 14px; gap:4px; }
  /* one row only */
  .wc-cell   { display:flex; flex-direction:column; align-items:center; }
  .wc-cell:nth-child(n+5) { display:none; }
  .wc-cell svg{ width:78px; height:78px; }
  .wc-hr     { font-size:15px; font-weight:700; }
  .wc-ct     { font-size:17px; font-weight:600; }
</style>

<div class="wc">
  <div class="wc-cur">
    {{ current.svg }}
    <div class="wc-temp">{{ current.temp }}&deg;</div>
    <div class="wc-sum">{{ current.summary }}</div>
    <div class="wc-hl">H {{ current.high }}&deg; &middot; L {{ current.low }}&deg;</div>
  </div>
  <div class="wc-grid">
    {% for h in hours %}
    <div class="wc-cell">
      <div class="wc-hr">{{ h.label }}</div>
      {{ h.svg }}
      <div class="wc-ct">{{ h.temp }}&deg;</div>
    </div>
    {% endfor %}
  </div>
</div>
