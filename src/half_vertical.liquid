{% comment %} Weather Circles — half_vertical (400x480), 2-day view.
  Custom CSS avoids lint-flagged properties (see full.liquid). {% endcomment %}
<style>
  .wc        { --f:'Inter',-apple-system,Helvetica,Arial,sans-serif;
               height:100%; display:flex; flex-direction:column; color:#000; }
  .wc-cur    { display:flex; align-items:center; place-content:center; gap:14px;
               border-bottom:2px solid #000; }
  .wc-cur svg{ width:128px; height:128px; }
  .wc-curtxt { display:flex; flex-direction:column; align-items:flex-start; }
  .wc-temp   { font:800 50px/1 var(--f); }
  .wc-sum    { font:600 19px/1.1 var(--f); }
  .wc-hl     { font:400 13px/1.3 var(--f); }
  .wc-days   { flex:1; display:flex; flex-direction:column; min-height:0; }
  .wc-day    { flex:1; display:flex; flex-direction:column; gap:2px; min-height:0; }
  .wc-day + .wc-day { border-top:2px solid #000; }
  .wc-dayhdr { display:flex; align-items:baseline; gap:8px; }
  .wc-dayname{ flex:1; font:800 18px/1.2 var(--f); }
  .wc-dayhl  { font:600 14px/1.2 var(--f); }
  .wc-row    { flex:1; display:grid; grid-template-columns:repeat(4,1fr); align-items:center; }
  .wc-cell   { display:flex; flex-direction:column; align-items:center; }
  .wc-cell svg{ width:62px; height:62px; }
  .wc-hr     { font:700 13px/1 var(--f); }
  .wc-ct     { font:600 15px/1 var(--f); }
  .wc-bar    { display:flex; align-items:center; place-content:center; height:30px;
               border-top:2px solid #000; font:600 13px/1 var(--f); }
</style>

<div class="wc">
  <div class="wc-cur">
    {{ current.svg }}
    <div class="wc-curtxt">
      <div class="wc-temp">{{ current.temp }}&deg;</div>
      <div class="wc-sum">{{ current.summary }}</div>
      <div class="wc-hl">H {{ current.high }}&deg; &middot; L {{ current.low }}&deg;</div>
      <div class="wc-hl">{{ current.wind }}</div>
    </div>
  </div>
  <div class="wc-days">
    {% for d in days %}
    <div class="wc-day">
      <div class="wc-dayhdr">
        <span class="wc-dayname">{{ d.label }}</span>
        <span class="wc-dayhl">H {{ d.high }}&deg; &middot; L {{ d.low }}&deg;</span>
      </div>
      <div class="wc-row">
        {% for c in d.cells %}
        <div class="wc-cell">
          <div class="wc-hr">{{ c.label }}</div>
          {{ c.svg }}
          <div class="wc-ct">{{ c.temp }}&deg;</div>
        </div>
        {% endfor %}
      </div>
    </div>
    {% endfor %}
  </div>
  <div class="wc-bar">{{ location }} &middot; {{ generated_at }}</div>
</div>
