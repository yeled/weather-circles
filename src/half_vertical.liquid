{% comment %} Weather Circles — half_vertical (400x480), 2-day view.
  Native framework text classes; custom CSS only for structural layout. {% endcomment %}
<style>
  .wc        { height:100%; display:flex; flex-direction:column; }
  .wc-cur    { display:flex; align-items:center; place-content:center; gap:14px;
               border-bottom:2px solid #000; }
  .wc-cur svg{ width:128px; height:128px; }
  .wc-curtxt { display:flex; flex-direction:column; align-items:flex-start; }
  .wc-days   { flex:1; display:flex; flex-direction:column; min-height:0; }
  .wc-day    { flex:1; display:flex; flex-direction:column; gap:2px; min-height:0; }
  .wc-day + .wc-day { border-top:2px solid #000; }
  .wc-dayhdr { display:flex; align-items:baseline; gap:8px; }
  .wc-row    { flex:1; display:grid; grid-template-columns:repeat(4,1fr); align-items:center; }
  .wc-cell   { display:flex; flex-direction:column; align-items:center; }
  .wc-plot   { position:relative; line-height:0; }
  .wc-plot svg{ width:72px; height:72px; }
  .wc-temp   { position:absolute; left:1px; top:-1px; line-height:1; }
  .grow      { flex:1; }
</style>

<div class="wc layout--col">
  <div class="wc-cur">
    {{ current.svg }}
    <div class="wc-curtxt">
      <span class="value value--large">{{ current.temp }}&deg;</span>
      <span class="title title--small">{{ current.summary }}</span>
      <span class="label label--small">H {{ current.high }}&deg; &middot; L {{ current.low }}&deg;</span>
      <span class="label label--small">{{ current.wind }}</span>
    </div>
  </div>
  <div class="wc-days">
    {% for d in days %}
    <div class="wc-day">
      <div class="wc-dayhdr">
        <span class="title title--small grow">{{ d.label }}</span>
        <span class="label label--small">H {{ d.high }}&deg; &middot; L {{ d.low }}&deg;</span>
      </div>
      <div class="wc-row">
        {% for c in d.cells %}
        <div class="wc-cell">
          <div class="wc-plot">
            {{ c.svg }}
            <span class="value value--xxsmall wc-temp">{{ c.temp }}</span>
          </div>
          <span class="label label--small">{{ c.label }}</span>
        </div>
        {% endfor %}
      </div>
    </div>
    {% endfor %}
  </div>
  <div class="title_bar">
    <span class="title">Weather Circles</span>
    <span class="instance">{{ location }} &middot; {{ generated_at }}</span>
  </div>
</div>
