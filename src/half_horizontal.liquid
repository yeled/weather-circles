{% comment %} Weather Circles — half_horizontal (800x240), 2-day view.
  Native framework text classes; custom CSS only for structural layout. {% endcomment %}
<style>
  .wc        { height:100%; display:flex; }
  .wc-cur    { flex:0 0 196px; display:flex; flex-direction:column;
               align-items:center; place-content:center; gap:2px;
               border-right:2px solid #000; }
  .wc-cur svg{ width:110px; height:110px; }
  .wc-days   { flex:1; display:flex; flex-direction:column; min-width:0; }
  .wc-day    { flex:1; display:flex; align-items:center; gap:10px; min-height:0; }
  .wc-day[data-rows="2"] { flex-grow:2; }
  .wc-day + .wc-day { border-top:2px solid #000; }
  .wc-dayhdr { flex:0 0 84px; display:flex; flex-direction:column; }
  .wc-row    { flex:1; display:grid; grid-template-columns:repeat(4,1fr); align-items:center; }
  .wc-cell   { display:flex; flex-direction:column; align-items:center; }
  .wc-plot   { position:relative; line-height:0; }
  .wc-plot svg{ width:66px; height:66px; }
  .wc-temp   { position:absolute; left:1px; top:-1px; line-height:1; }
</style>

<div class="wc">
  <div class="wc-cur">
    {{ current.svg }}
    <span class="value">{{ current.temp }}&deg;</span>
    <span class="label label--small">{{ current.summary }}</span>
    <span class="label label--small">H {{ current.high }}&deg; &middot; L {{ current.low }}&deg;</span>
  </div>
  <div class="wc-days">
    {% for d in days %}
    <div class="wc-day" data-rows="{{ d.rows }}">
      <div class="wc-dayhdr">
        <span class="title title--small">{{ d.label }}</span>
        <span class="label label--small">H {{ d.high }}&deg; &middot; L {{ d.low }}&deg;</span>
      </div>
      <div class="wc-row">
        {% for c in d.cells %}
        <div class="wc-cell">
          <div class="wc-plot">
            {{ c.svg }}
            <span class="value value--xxsmall wc-temp">{{ c.temp }}</span>
          </div>
          <span class="label label--small">{{ c.label }}</span>
        </div>
        {% endfor %}
      </div>
    </div>
    {% endfor %}
  </div>
</div>
