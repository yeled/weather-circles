{% comment %} Weather Circles — quadrant (400x240), 2-day summary.
  Native framework text classes; custom CSS only for structural layout. {% endcomment %}
<style>
  .wc        { height:100%; display:flex; }
  .wc-cur    { flex:0 0 210px; display:flex; align-items:center; place-content:center;
               gap:10px; border-right:2px solid #000; }
  .wc-cur svg{ width:114px; height:114px; }
  .wc-curtxt { display:flex; flex-direction:column; align-items:flex-start; }
  .wc-days   { flex:1; display:grid; grid-template-columns:repeat(2,1fr); align-items:center; }
  .wc-dcard  { display:flex; flex-direction:column; align-items:center; gap:1px; }
  .wc-dcard svg{ width:66px; height:66px; }
</style>

<div class="wc">
  <div class="wc-cur">
    {{ current.svg }}
    <div class="wc-curtxt">
      <span class="value">{{ current.temp }}&deg;</span>
      <span class="label label--small">{{ current.summary }}</span>
      <span class="label label--small">H {{ current.high }}&deg; &middot; L {{ current.low }}&deg;</span>
    </div>
  </div>
  <div class="wc-days">
    {% for d in days %}
    <div class="wc-dcard">
      <span class="title title--small">{{ d.label }}</span>
      {{ d.svg }}
      <span class="label label--small">H {{ d.high }}&deg; &middot; L {{ d.low }}&deg;</span>
    </div>
    {% endfor %}
  </div>
</div>
