{% comment %} Weather Circles — full (800x480), 2-day view.
  Text uses the native framework classes (value/title/label) for crisp e-ink
  rendering; custom CSS only handles structural layout (flex/grid/gap/border/
  svg sizing) and avoids the limited_inline_styles-flagged properties. {% endcomment %}
<style>
  .wc        { width:100%; height:100%; display:flex; flex-direction:column; }
  .wc-main   { display:flex; flex:1; gap:18px; min-height:0; }
  .wc-cur    { flex:0 0 224px; display:flex; flex-direction:column;
               align-items:center; place-content:center; gap:4px;
               border-right:2px solid #000; }
  .wc-cur svg{ width:140px; height:140px; }
  .wc-days   { flex:1; display:flex; flex-direction:column; min-width:0; }
  .wc-day    { flex:1; display:flex; flex-direction:column; gap:2px; min-height:0; }
  .wc-day + .wc-day { border-top:2px solid #000; }
  .wc-dayhdr { display:flex; align-items:baseline; gap:8px; }
  .wc-row    { flex:1; display:grid; grid-template-columns:repeat(4,1fr); align-items:center; }
  .wc-cell   { display:flex; flex-direction:column; align-items:center; gap:2px; }
  .wc-plot   { position:relative; line-height:0; }
  .wc-plot svg{ width:86px; height:86px; }
  .wc-temp   { position:absolute; left:2px; top:0; line-height:1; }  /* station-model: temp upper-left */
  .grow      { flex:1; }
</style>

<div class="wc layout layout--col">
  <div class="wc-main">
    <div class="wc-cur">
      {{ current.svg }}
      <span class="value value--large">{{ current.temp }}&deg;</span>
      <span class="title title--small">{{ current.summary }}</span>
      <span class="label">H {{ current.high }}&deg; &middot; L {{ current.low }}&deg;</span>
      <span class="label label--small">{{ current.wind }} &middot; {{ current.oktas }}/8 cloud</span>
    </div>
    <div class="wc-days">
      {% for d in days %}
      <div class="wc-day">
        <div class="wc-dayhdr">
          <span class="title title--small grow">{{ d.label }}</span>
          <span class="label label--small">H {{ d.high }}&deg; &middot; L {{ d.low }}&deg;</span>
        </div>
        <div class="wc-row">
          {% for c in d.cells %}
          <div class="wc-cell">
            <div class="wc-plot">
              {{ c.svg }}
              <span class="value value--xsmall wc-temp">{{ c.temp }}</span>
            </div>
            <span class="label label--small">{{ c.label }}</span>
          </div>
          {% endfor %}
        </div>
      </div>
      {% endfor %}
    </div>
  </div>
  <div class="title_bar">
    <span class="title">Weather Circles</span>
    <span class="instance">{{ location }} &middot; {{ generated_at }}</span>
  </div>
</div>
